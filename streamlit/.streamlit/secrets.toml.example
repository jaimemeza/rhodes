[snowflake]
account   = "<YOUR_ACCOUNT_IDENTIFIER>"
user      = "STREAMLIT_USER"
role      = "RHODES_READER"
warehouse = "RHODES_BI_WH"
database  = "RHODES"
schema    = "ANALYTICS"

# Paste the full PEM including BEGIN/END lines.
# The triple-quoted string preserves the newlines that PEM requires.
private_key = """-----BEGIN PRIVATE KEY-----
MIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...
...full body here...
-----E